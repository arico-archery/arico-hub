# ─────────────────────────────────────────────────────────────
# ARICO Hub 환경변수 예시 — 이 파일을 복사해 `.env` 로 만들고 값을 채우세요.
#   cp .env.example .env
# `.env` 는 git에 커밋되지 않습니다(.gitignore).
# ─────────────────────────────────────────────────────────────

# ── 데이터베이스 (Supabase Postgres) ──
# DATABASE_URL: 런타임용 (Connection pooling, 포트 6543, ?pgbouncer=true)
# DIRECT_URL : 마이그레이션/db push용 (Direct connection, 포트 5432)
# Supabase 대시보드 > Project Settings > Database > Connection string 에서 확보
DATABASE_URL="postgresql://postgres.xxxx:[PASSWORD]@aws-0-ap-northeast-1.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.xxxx:[PASSWORD]@aws-0-ap-northeast-1.pooler.supabase.com:5432/postgres"

# ── 인증 (간단 로그인) ──
# APP_PASSWORD: 앱 접속 비밀번호 (배포 전 반드시 강력한 값으로 변경)
# AUTH_SECRET : 세션 쿠키 서명용 비밀키 (예: `openssl rand -hex 32`)
APP_PASSWORD="change-this-password"
AUTH_SECRET="change-this-to-a-long-random-secret-string"

# ── 로컬 SQLite 데이터 이전 시에만 사용(선택) ──
# scripts/migrate-sqlite-to-postgres.mjs 가 읽는 기존 로컬 DB 경로
# LEGACY_SQLITE_PATH="./prisma/dev.db"
