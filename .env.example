# ─────────────────────────────────────────────────────────────
# ARICO Hub 환경변수 예시 — 복사해 `.env` 로 만들고 값을 채우세요.
#   cp .env.example .env
# `.env` 는 git에 커밋되지 않습니다(.gitignore).
# ─────────────────────────────────────────────────────────────

# ── 데이터베이스 (Supabase Postgres) ──
# DATABASE_URL: 런타임 (Connection pooling, 6543, ?pgbouncer=true)
# DIRECT_URL : 마이그레이션/db push (Direct/Session, 5432)
DATABASE_URL="postgresql://postgres.xxxx:[PASSWORD]@aws-1-ap-northeast-1.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.xxxx:[PASSWORD]@aws-1-ap-northeast-1.pooler.supabase.com:5432/postgres"

# ── 인증 (이메일/비밀번호 회원가입) ──
# AUTH_SECRET: 세션 쿠키 서명 키 (openssl rand -hex 32)
AUTH_SECRET="change-this-to-a-long-random-secret"

# 가입 허용 도메인 / 슈퍼 어드민은 코드 상수로 관리: src/lib/session.ts
#   ALLOWED_DOMAIN = 'arico.group'  (회원가입 시 이 도메인 이메일만 허용)
#   SUPER_ADMINS   = ['sms@arico.group', 'sbs@arico.group']
