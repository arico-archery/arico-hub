# ─────────────────────────────────────────────────────────────
# ARICO Hub 환경변수 예시 — 복사해 `.env` 로 만들고 값을 채우세요.
#   cp .env.example .env
# `.env` 는 git에 커밋되지 않습니다(.gitignore).
# ─────────────────────────────────────────────────────────────

# ── 데이터베이스 (Supabase Postgres) ──
# DATABASE_URL: 런타임 (Connection pooling, 6543, ?pgbouncer=true)
# DIRECT_URL : 마이그레이션/db push (Direct/Session, 5432)
DATABASE_URL="postgresql://postgres.xxxx:[PASSWORD]@aws-1-ap-northeast-1.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.xxxx:[PASSWORD]@aws-1-ap-northeast-1.pooler.supabase.com:5432/postgres"

# ── 인증 (NextAuth + Microsoft Entra ID) ──
# AUTH_SECRET: 세션 서명 키 (openssl rand -hex 32)
AUTH_SECRET="change-this-to-a-long-random-secret"
AUTH_TRUST_HOST="true"
# AUTH_URL: 로컬은 http://localhost:3000, 배포는 https://<도메인>
AUTH_URL="http://localhost:3000"
# Azure(Entra ID) 앱 등록 값 — Azure Portal > App registrations
AUTH_MICROSOFT_ENTRA_ID_ID="<application(client) id>"
AUTH_MICROSOFT_ENTRA_ID_SECRET="<client secret value>"
# ISSUER: https://login.microsoftonline.com/<tenant-id>/v2.0  (단일 테넌트)
AUTH_MICROSOFT_ENTRA_ID_ISSUER="https://login.microsoftonline.com/<tenant-id>/v2.0"

# 접근 허용: @arico.group 도메인 계정만 (src/auth.ts ALLOWED_DOMAIN)
# 슈퍼 어드민: sms@arico.group, sbs@arico.group (src/auth.ts SUPER_ADMINS)
