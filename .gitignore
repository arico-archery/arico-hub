# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# ── 사업 데이터·로컬 DB (공개 저장소 커밋 금지) ──
# SQLite 로컬 DB 및 백업
prisma/*.db
prisma/*.db-journal
prisma/*.db.backup*
*.sqlite
*.sqlite3
# 공급사 가격표·원본 데이터(독점 데이터)
/*.csv
/*.xlsx
/*.xls
# 매뉴얼 캡처는 추적(public/manual/*.png), 그 외 임시 산출물 제외
arico_catalog*.json
/C:Temp*

# python
__pycache__/
*.pyc
*.pyo
.venv/
venv/

# 로컬 CLI 도구·임시 비밀값
.tools/

.vercel
